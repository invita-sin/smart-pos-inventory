# SmartPOS Inventory — Environment Variables

# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# --- GitHub Actions (set as repository Secrets) ---
# Settings > Secrets and variables > Actions > New repository secret
# Name: SUPABASE_URL          Value: <same as VITE_SUPABASE_URL>
# Name: SUPABASE_PUBLISHABLE_KEY  Value: <same as VITE_SUPABASE_PUBLISHABLE_KEY>
